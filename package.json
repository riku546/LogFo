      "picomatch@^2.3.1": "2.3.2",
      "qs": ">=6.14.2",
      "esbuild": ">=0.25.0",
      "@smithy/config-resolver": ">=4.4.0",
      "undici": ">=7.24.0",
      "rollup": ">=4.59.0",
      "vite": "7.3.2"
