{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "biome format --write",
    "biome:fix": "biome check --write",
    "biome:check": "biome check",
    "depcruise": "depcruise --config dependency-cruiser.cjs src --output-type err",
    "generate-types": "wrangler types",
    "typecheck": "pnpm generate-types && tsc --noEmit",
    "test:unit": "vitest test/unit",
    "test:integration": "vitest test/integration",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@openrouter/ai-sdk-provider": "^2.6.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "ai": "^6.0.161",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hash-wasm": "^4.12.0",
    "hono": "4.12.14",
    "pdfjs-serverless": "^1.2.2",
    "workers-ai-provider": "^3.1.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@vitest/coverage-istanbul": "^4.1.4",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
