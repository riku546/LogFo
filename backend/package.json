{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "biome format --write",
    "biome:fix": "biome check --write",
    "biome:check": "biome check",
    "depcruise": "depcruise --config dependency-cruiser.cjs src --output-type err",
    "generate-types": "wrangler types",
    "typecheck": "pnpm generate-types && tsc --noEmit",
    "test:unit": "vitest test/unit",
    "test:integration": "vitest test/integration",
    "test": "vitest",
    "test:coverage": "vitest run test/unit --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@paralleldrive/cuid2": "^3.0.6",
    "ai": "^6.0.105",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hash-wasm": "^4.12.0",
    "hono": "4.12.12",
    "pdfjs-serverless": "^1.1.0",
    "workers-ai-provider": "^3.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^25.0.9",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.7",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.70.0"
  }
}
